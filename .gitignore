# sensitive settings
zsh/local
!zsh/local/.gitkeep

zsh/data
!zsh/data/.gitkeep

# swap files
zsh/*.sw[po]

# netrwhist history file
config/nvim/.netrwhist

config/nvim/.tmp
!config/nvim/.tmp/.gitkeep

config/nvim/.undo
!config/nvim/.undo/.gitkeep

# Ignore all bundles
config/nvim/plugged

!config/fish
config/fish/*
!config/fish/config.fish
!config/fish/fishfile

!config/fish/functions
config/fish/functions/*
!config/fish/functions/tldr.fish

!config/fish/conf.d
config/fish/conf.d/*
!config/fish/conf.d/000-*
!config/fish/conf.d/999-*
config/fish/conf.d/999-private.fish
config/fish/conf.d/000-private.fish

# The following bits are copied over when running ./install
# so can be ignored
config/nvim/autoload/plug.vim
zsh/autoload/bundles.zsh
local/bin/diff-so-fancy
