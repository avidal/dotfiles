# Taken from github.com/bitprophet/dotfiles

# Generic "move me to my project dir" function/alias.
#
# Tries to "workon" a Python virtualenv, then (either way) switches to the
# directory in question.
#
# This means that we can A) use this for non-Python projects, and B) avoid
# having to add the 'cd' call to every. single. virtualenv's postactivate
# script.
#
# Also deactivates any currently active virtualenv, just for neatness' sake.
#
CODE=$HOME/Code

function wk() {
    # Try to find the given folder and cd to it.
    FOLDERS=($CODE/github.com $CODE/code.cfops.it $CODE/gitlab.com $CODE/bitbucket.org)
    for folder in $FOLDERS; do
        target=$folder/$1
        if [[ -d $target ]]; then
            cd $target
            return 0
        fi
    done
    return 1
}

# Completion
function _wk() {
    compadd $(find $CODE -type d -mindepth 2 -maxdepth 3 -not -ipath '*/.git*' | \
              rg --color=never -v '(bitbucket.org|gitlab.com|github.com|code.cfops.it)(/[^/]+)?$' | \
              sed -E "s:^$CODE/((bitbucket.org|gitlab.com|github.com|code.cfops.it)/)?::" 2>/dev/null)
}

compdef _wk wk
